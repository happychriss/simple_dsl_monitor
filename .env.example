# Copy to .env and adjust. Never commit .env

# FritzBox TR-064 credentials (used by fritz_status_service.py)
FRITZ_HOST=fritz.box
FRITZ_USER=
FRITZ_PASSWORD=
FRITZ_STATUS_PORT=9077

# Fritz status bridge URL (used by probe.py and web.py)
# This should point at fritz_status_service.py (local-only).
DSL_CONN_STATUS_URL=http://127.0.0.1:9077/status

# -------------------------------------------------------------------
# Core DSL monitor (probe.py)
# -------------------------------------------------------------------
# Ping target that defines reachability.
DSL_MONITOR_PING_TARGET=8.8.8.8
# SQLite database path (probe writes, web reads)
DSL_MONITOR_LOG=./dsl_log.db

# UI display retention in days (web.py filters to the last N days)
DSL_MONITOR_RETENTION_DAYS=7

# DB pruning retention in days (probe.py deletes old rows once/hour).
# Default 0 = keep forever (recommended).
DSL_MONITOR_DB_RETENTION_DAYS=0

# Ping cadence and failure detection
# Ping every N seconds (15s recommended)
DSL_MONITOR_PING_INTERVAL_SECONDS=10
# After N consecutive failed pings a DSL event is started
DSL_MONITOR_FAILURE_THRESHOLD=2
# Ping timeout per single ping (seconds, passed as -W to the ping command).
# If a single ping gets no reply within this time → ping_ok=0 (failure).
# This is NOT the latency threshold – see PING_LATENCY_THRESHOLD_MS below.
DSL_MONITOR_PING_TIMEOUT_SECONDS=5

# Latency threshold (ms) for mobile-fallback detection.
# If a ping succeeds but measured latency exceeds this value, it is treated
# as a high-latency failure and immediately starts a DSL event (no consecutive
# failure count needed).  Typical DSL latency is 10-20 ms; mobile fallback
# routes through the cellular network at 100-200 ms.
# Set to 0 to disable high-latency detection entirely.
DSL_MONITOR_PING_LATENCY_THRESHOLD_MS=100

# DSL event maximum duration in seconds (45min = 2700)
# If Fritz never reports "dsl" again, the event is force-closed after this time.
DSL_MONITOR_DSL_EVENT_MAX_SECONDS=2700

# Fritz connection type polling (two rates)
# During a DSL event: poll Fritz every N seconds to detect mobile→dsl recovery.
DSL_MONITOR_CONN_TYPE_POLL_INTERVAL_SECONDS=60
# Normal mode (no event): poll Fritz every N seconds (default 20 min = 1200).
# Proactively detects dsl→mobile switches even when pings are fine.
DSL_MONITOR_CONN_TYPE_NORMAL_POLL_INTERVAL_SECONDS=1200

# Mobile marking
# If mobile is active for more than this many seconds, UI buckets turn yellow.
DSL_MONITOR_MOBILE_YELLOW_THRESHOLD_SECONDS=30

# -------------------------------------------------------------------
# HTTP probe (generic download/reachability check)
# -------------------------------------------------------------------
# URL to download every interval; timeout creates/extends a DSL event.
DSL_MONITOR_HTTP_PROBE_URL=https://www.tagesschau.de/tagesthemen
# Interval in seconds (5min = 300)
DSL_MONITOR_HTTP_PROBE_INTERVAL_SECONDS=300
# HTTP request timeout in seconds; on timeout the probe raises an error.
DSL_MONITOR_HTTP_PROBE_TIMEOUT_SECONDS=15

# -------------------------------------------------------------------
# Web UI (web.py)
# -------------------------------------------------------------------
DSL_MONITOR_WEB_HOST=0.0.0.0 #binds to all interfaces; adjust if you want to bind to localhost only
DSL_MONITOR_WEB_PORT=9076
DSL_MONITOR_BUCKET_MINUTES=5

# Fritz status fetch timeout used by the web UI endpoint /api/fritz_status
DSL_MONITOR_FRITZ_STATUS_TIMEOUT_SECONDS=10
# UI-side throttle: only poll Fritz while DSL event active, and only once per interval.
DSL_MONITOR_FRITZ_UI_POLL_INTERVAL_SECONDS=60

# -------------------------------------------------------------------
# Orchestrator (run.py)
# -------------------------------------------------------------------
# Start fritz_status_service.py automatically (1=true, 0=false)
DSL_MONITOR_START_FRITZ_BRIDGE=1
